- content_for(:title) { "Themes — Plural Profiles" }

%h1 Themes

.theme-import{data: { controller: "theme-import", "theme-import-new-url-value": new_our_theme_path }}
  = link_to "New theme", new_our_theme_path, class: "btn"
  %button.btn.btn--outline{type: "button", data: { action: "click->theme-import#open" }} Import theme

  %dialog.import-dialog{data: { "theme-import-target": "dialog", action: "click->theme-import#backdropClick" }}
    %form{data: { action: "submit->theme-import#import" }}
      %h2 Import theme
      %p Paste the CSS block copied from the theme editor below.
      %textarea.import-dialog__textarea{data: { "theme-import-target": "cssInput" }, rows: 12, placeholder: ":root {\n  --page-bg: #123456;\n  ...\n}", spellcheck: false}
      %p.import-dialog__error{data: { "theme-import-target": "error" }, role: "alert"}
      .import-dialog__actions
        %button.btn{type: "submit"} Import
        %button.btn.btn--secondary{type: "button", data: { action: "click->theme-import#close" }} Cancel

.theme-tag-filter
  %span.theme-tag-filter__label Filter by tag:
  - Theme::TAGS.each do |value, label|
    - active = @filter_tags.include?(value)
    - new_tags = active ? @filter_tags - [value] : @filter_tags + [value]
    = link_to label, our_themes_path(tags: new_tags), class: "tag tag--filter #{'tag--filter-active' if active}"
  - if @filter_tags.any?
    = link_to "Clear filter", our_themes_path, class: "theme-tag-filter__clear"

- if @themes.any?
  .card-list
    - @themes.each do |theme|
      .card.card--stacked
        .card__main
          .card__header
            %h3= link_to theme.name, edit_our_theme_path(theme)
            - if Current.user.active_theme_id == theme.id
              %span.tag.tag--active active
              = link_to "Deactivate", deactivate_our_themes_path, data: { turbo_method: :patch }, class: "btn btn--small"
            - else
              = link_to "Activate", activate_our_theme_path(theme), data: { turbo_method: :patch }, class: "btn btn--small"
          .card__actions
            = link_to "Edit", edit_our_theme_path(theme), class: "btn btn--small btn--secondary"
            = link_to "Duplicate", duplicate_our_theme_path(theme), data: { turbo_method: :post }, class: "btn btn--small btn--secondary"
            = link_to "Delete", our_theme_path(theme), data: { turbo_method: :delete, turbo_confirm: "Are you sure you want to delete this theme?" }, class: "btn btn--small btn--danger"
        - if theme.tags.any?
          .card__tags
            - theme.tags.each do |tag|
              %span.tag.tag--theme= Theme::TAGS[tag] || tag
- else
  .card
    - if @filter_tags.any?
      %p No themes match the selected tags.
    - else
      %p You haven't created any themes yet. Themes let you customise the colours used across the site.

